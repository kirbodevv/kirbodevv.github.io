---
---

<section id="contact" class="contact-section">
  <div class="container">
    <span class="section-label">Get in touch</span>
    <h2 class="section-title">Contact</h2>
    <p class="section-body" style="margin-bottom: 2.75rem;">
      Have a project in mind, a question, or just want to say hi?
      I'm always open to interesting conversations.
    </p>

    <div class="contact-cards">
      <!-- GitHub -->
      <a
        href="https://github.com/kirbodevv"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card card"
      >
        <div class="contact-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">GitHub</span>
          <span class="contact-value">@kirbodevv</span>
        </div>
        <svg
          class="arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17L17 7M7 7h10v10"></path>
        </svg>
      </a>

      <!-- Email placeholder — update with your real address -->
      <a
        href="mailto:hello@kirbodevv.dev"
        class="contact-card card"
      >
        <div class="contact-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">Email</span>
          <span class="contact-value">hello@kirbodevv.dev</span>
        </div>
        <svg
          class="arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17L17 7M7 7h10v10"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 7rem 0;
  }

  .contact-cards {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    min-width: 260px;
    flex: 1;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: var(--surface-container-high);
    color: var(--primary);
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .contact-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: var(--on-surface-variant);
  }

  .contact-value {
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--on-background);
  }

  .arrow {
    color: var(--on-surface-variant);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition:
      opacity 0.2s,
      transform 0.2s;
    flex-shrink: 0;
  }

  .contact-card:hover .arrow {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>
