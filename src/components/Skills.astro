---
const skillGroups = [
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
        label: "Languages",
        skills: ["Python", "Rust", "TypeScript", "Go", "Lua"],
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12c0-2.76 1.12-5.26 2.93-7.07"/><path d="M12 6v6l4 2"/></svg>`,
        label: "Backend & AI",
        skills: [
            "REST APIs",
            "FastAPI",
            "LLM Integration",
            "Embeddings",
            "RAG",
            "Tool Calling",
        ],
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
        label: "Game Development",
        skills: [
            "Game Systems Design",
            "Minecraft Datapacks",
            "Procedural Generation",
            "mcfunction",
        ],
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
        label: "Tools & Infra",
        skills: ["Docker", "Git", "Linux", "CI/CD", "PostgreSQL", "SQLite"],
    },
];
---

<section id="skills" class="skills-section">
    <div class="container">
        <span class="section-label">What I work with</span>
        <h2 class="section-title">Skills</h2>

        <div class="skill-groups">
            {
                skillGroups.map((group) => (
                    <div class="skill-group card">
                        <div class="group-header">
                            <span class="group-icon" set:html={group.icon} />
                            <h3 class="group-title">{group.label}</h3>
                        </div>
                        <div class="badges">
                            {group.skills.map((skill) => (
                                <span class="badge">{skill}</span>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .skills-section {
        padding: 7rem 0;
    }

    .skill-groups {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-top: 2.5rem;
    }

    .skill-group {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .group-header {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .group-icon {
        display: flex;
        align-items: center;
        color: var(--primary);
        flex-shrink: 0;
    }

    .group-title {
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--on-surface);
        margin: 0;
    }

    .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    @media (max-width: 620px) {
        .skill-groups {
            grid-template-columns: 1fr;
        }
    }
</style>
